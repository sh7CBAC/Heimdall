  "overrides": {
    "dompurify": "^3.4.11",
    "react-copy-to-clipboard": "^5.1.1",
    "react-inspector": "^9.0.0",
    "react-debounce-input": {
      "react": "^19.0.0"
    },
    "swagger-ui-react": {
      "js-yaml": "^4.2.0"
    }
  },
  "allowScripts": {
    "@scarf/scarf": false,
    "@tree-sitter-grammars/tree-sitter-yaml": false,
    "tree-sitter": false,
    "core-js-pure": false,
    "tree-sitter-json": false
  }
}

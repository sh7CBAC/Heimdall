    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.21",
    "embla-carousel-react": "^8.6.0",
    "es-toolkit": "^1.49.0",
    "i18next": "^26.3.1",
    "lucide-react": "^0.577.0",
    "otpauth": "^9.5.1",
    "persian-calendar-suite": "^1.5.5",
    "qs": "^6.15.2",
    "react": "^19.2.7",
    "react-ace": "^14.0.1",
    "react-day-picker": "^9.7.0",
